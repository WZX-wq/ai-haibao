AI_BAILIAN_API_KEY=
AI_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com

AI_COPY_PROVIDER=aliyun-bailian
AI_IMAGE_PROVIDER=aliyun-bailian
AI_BACKGROUND_PROVIDER=aliyun-bailian
AI_IMAGE_EDIT_PROVIDER=aliyun-bailian
AI_CUTOUT_PROVIDER=rembg,aliyun-human-cutout,mock

AI_COPY_MODEL=qwen3.5-plus
AI_PALETTE_MODEL=qwen3.6-plus
AI_RELAYOUT_MODEL=qwen3.6-plus
AI_MULTIMODAL_LAYOUT_MODEL=qwen-vl-max-latest
AI_FAST_COPY_MODEL=qwen3.6-flash
AI_FAST_PALETTE_MODEL=qwen3.6-flash
AI_FAST_RELAYOUT_MODEL=qwen3.6-flash
AI_FAST_MULTIMODAL_LAYOUT_MODEL=qwen-vl-plus-latest
AI_IMAGE_MODEL=qwen-image-2.0-pro
AI_BACKGROUND_MODEL=wanx-background-generation-v2
AI_IMAGE_EDIT_MODEL=qwen-image-edit-plus
AI_CUTOUT_MODEL=image-instance-segmentation
AI_CUTOUT_REMBG_MODEL=u2net
AI_CUTOUT_PYTHON=python
# 高清远程抠图优先走阿里云视觉智能开放平台；配置后会直接读取本地文件流，避免临时公网中转
# AI_VIAPI_ACCESS_KEY_ID=
# AI_VIAPI_ACCESS_KEY_SECRET=
# AI_VIAPI_REGION=cn-shanghai
# AI_VIAPI_IMAGESEG_ENDPOINT=imageseg.cn-shanghai.aliyuncs.com
# AI_VIAPI_ASYNC_ENDPOINT=viapi.cn-shanghai.aliyuncs.com
# AI_VIAPI_CUTOUT_MODE=human-first
# 若服务静态图已有公网可访问域名，填写后远程抠图会直接使用该地址，避免再次上传
# AI_CUTOUT_SOURCE_BASE_URL=https://your-domain.com/static/cutout
# 远程抠图会优先走阿里云百炼临时 OSS 上传；仅在当前环境不可用时才会改走临时公网文件中转
# 远程抠图轮询节奏（默认 1500ms * 120 次）
# AI_CUTOUT_TASK_POLL_INTERVAL_MS=1500
# AI_CUTOUT_TASK_MAX_POLLS=120
# 远程抠图上传轻量化：超大图会先自动缩小再送远程模型，提升上传与处理速度
# AI_CUTOUT_UPLOAD_MAX_SIDE=2048
# AI_CUTOUT_UPLOAD_SIZE_LIMIT_MB=3
# AI_CUTOUT_UPLOAD_JPEG_QUALITY=88

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=poster_design
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00

APP_BASE_URL=http://127.0.0.1:5173
FRONTEND_PUBLIC_BASE_URL=http://127.0.0.1:5173
CALLBACK_ROUTE=/oauth/callback
POST_LOGIN_REDIRECT=/account
TOKEN_STORAGE_MODE=localStorage
SESSION_EXPIRE_DAYS=7
ADMIN_AUTH_TOKEN=

# 鲲穹统一登录中心：与 deploy/env.template 一致；本地开发按需填写
OAUTH_PROVIDER_NAME=kunqiong-login
OAUTH_BASE_URL=https://login.kunqiongai.com
OAUTH_AUTHORIZE_PATH=authorize.html
OAUTH_TOKEN_BASE_URL=https://login.kunqiongai.com
OAUTH_TOKEN_PATH=api/oauth/token
OAUTH_USERINFO_BASE_URL=
OAUTH_USERINFO_PATH=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:5173/oauth/callback
OAUTH_TOKEN_REQUEST_FORMAT=json
OAUTH_SCOPE=
OAUTH_LOGOUT_URL=
OAUTH_OMIT_RESPONSE_TYPE=1
# 勿填飞书 open/accounts 域名；确须直连飞书开放平台时设为 1
# OAUTH_ALLOW_FEISHU_DIRECT=1

# 模板主图写入 JSON 的前缀；留空则由 api 使用相对路径 /static/（推荐）
# SERVICE_STATIC_BASE_URL=
# SERVICE_SCREENSHOT_LIST_BASE=

# 生产截图：Puppeteer 打开的编辑器基址（Docker 内常用 http://web）
# PUPPETEER_PAGE_BASE_URL=
# 上传与截图文件目录（默认开发用项目 static，生产可设绝对路径）
# FILE_STORAGE_PATH=
# Chromium 路径（Docker 常见 /usr/bin/chromium）
# PUPPETEER_EXECUTABLE_PATH=
