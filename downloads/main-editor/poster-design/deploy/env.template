# cp env.template .env 后填写远程库与密钥

# 宿主机映射到 web 容器 80 的端口；宝塔整站反代须指向同一端口（例：8080 或 8098）
HTTP_PUBLISH_PORT=8080

# 宝塔反代目标必须是「web 容器」映射端口（与上项一致，如 http://127.0.0.1:8098），由容器内 Nginx 再转发 /api、/static。
# 切勿把域名反代到 api 的 7001：/oauth/callback 与 SPA 会 404，侧栏素材图 /static、/api/screenshots 也会异常。

# 前端 Docker 构建：一般留空即可（浏览器请求同端口 /api、/static，由 Nginx 转到 api 容器）。
# 若填 http://127.0.0.1:7001，公网 IP/域名访问时图片与接口会被浏览器「私网访问」策略拦截。
# VITE_API_URL=
# VITE_SCREEN_URL=

# Docker 构建加速（国内源，可选；与 deploy/docker-compose.yaml 中变量对应）
# DOCKER_HUB_MIRROR=docker.m.daocloud.io
# APT_MIRROR_HOST=mirrors.aliyun.com

# 远程 MySQL：主机、库名、账号、密码（与现有环境一致）
DB_HOST=
DB_PORT=3306
DB_NAME=poster_design
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00

NODE_ENV=production
PORT=7001
FILE_STORAGE_PATH=/app/static/
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_PAGE_BASE_URL=http://web

# 模板主图/列表 thumb 写入给前端的 URL 前缀。留空则 api 使用相对路径 /static/、/api/…（推荐，避免 JSON 里出现 127.0.0.1）
# SERVICE_STATIC_BASE_URL=
# 模板列表缩略图截图接口站点根，一般留空即可（同源 /api/screenshots）
# SERVICE_SCREENSHOT_LIST_BASE=
# api 容器内自调截图接口用（一般留空即可，默认 http://127.0.0.1:${PORT}）
# INTERNAL_API_ORIGIN=

APP_BASE_URL=https://poster.kunqiongai.com
FRONTEND_PUBLIC_BASE_URL=https://poster.kunqiongai.com
CALLBACK_ROUTE=/oauth/callback
POST_LOGIN_REDIRECT=/account
TOKEN_STORAGE_MODE=localStorage
SESSION_EXPIRE_DAYS=7

ADMIN_AUTH_TOKEN=请改为随机长字符串

# OAuth2：鲲穹统一登录中心（与 deploy/oauth2-api.md 一致：authorize.html + POST /api/oauth/token，JSON 换票）
# 切勿把 OAUTH_BASE_URL / OAUTH_TOKEN_BASE_URL 填成 accounts.feishu.cn、open.feishu.cn（飞书开放平台），
# 否则浏览器会整页打开飞书登录，而不是鲲穹；鲲穹域名应为 https://login.kunqiongai.com
# 填写完整后，访问 /login 会自动跳转鲲穹；企业租户可能经飞书等授权，属正常流程。
# 若暂不启用统一登录：清空 OAUTH_CLIENT_ID、OAUTH_CLIENT_SECRET 等必填项，登录页将提供「进入编辑器」。
# 已启用鲲穹但想先停留在说明页：打开 /login?manual=1
# 在 login.kunqiongai.com 注册应用后填写 client_id / client_secret；回调地址须与注册一致。
# 极少数场景必须直连飞书开放平台时：OAUTH_ALLOW_FEISHU_DIRECT=1（不推荐）
OAUTH_PROVIDER_NAME=kunqiong-login
OAUTH_BASE_URL=https://login.kunqiongai.com
OAUTH_AUTHORIZE_PATH=authorize.html
OAUTH_TOKEN_BASE_URL=https://login.kunqiongai.com
OAUTH_TOKEN_PATH=api/oauth/token
OAUTH_USERINFO_BASE_URL=
OAUTH_USERINFO_PATH=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# 须与鲲穹控制台「回调地址」完全一致；服务端优先使用此项，避免用 IP:端口访问站点时与控制台登记的 https 域名不一致导致 400
OAUTH_REDIRECT_URI=https://poster.kunqiongai.com/oauth/callback
OAUTH_TOKEN_REQUEST_FORMAT=json
OAUTH_SCOPE=
OAUTH_LOGOUT_URL=
OAUTH_OMIT_RESPONSE_TYPE=1

AI_BAILIAN_API_KEY=
AI_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com
AI_COPY_PROVIDER=aliyun-bailian
AI_IMAGE_PROVIDER=aliyun-bailian
AI_BACKGROUND_PROVIDER=aliyun-bailian
AI_IMAGE_EDIT_PROVIDER=aliyun-bailian
AI_CUTOUT_PROVIDER=rembg,aliyun-human-cutout,mock
AI_COPY_MODEL=qwen3.5-plus
AI_IMAGE_MODEL=qwen-image-2.0-pro
AI_BACKGROUND_MODEL=wanx-background-generation-v2
AI_IMAGE_EDIT_MODEL=qwen-image-edit-plus
AI_CUTOUT_MODEL=image-instance-segmentation
AI_CUTOUT_REMBG_MODEL=u2net
AI_CUTOUT_PYTHON=python3
# 部署建议：本地模型优先，云服务兜底
# AI_CUTOUT_PROVIDER=rembg,aliyun-human-cutout,mock
# rembg 模型缓存目录（由 docker-compose 挂载到卷，避免重复下载）
# XDG_CACHE_HOME=/app/.cache
