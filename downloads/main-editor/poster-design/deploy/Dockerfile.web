# 不使用 # syntax=docker/dockerfile:1，避免部分云镜像站拉取 docker/dockerfile 元数据失败（如腾讯云 500）。
# 基础镜像走国内 Docker Hub 代理（默认 DaoCloud）；可用 build-arg REGISTRY_PREFIX 覆盖
ARG REGISTRY_PREFIX=docker.m.daocloud.io
FROM ${REGISTRY_PREFIX}/library/node:20-bookworm AS builder
WORKDIR /app

ENV NPM_CONFIG_REGISTRY=https://registry.npmmirror.com

COPY package.json package-lock.json ./
COPY packages/color-picker/package.json ./packages/color-picker/
COPY packages/image-extraction/package.json ./packages/image-extraction/

RUN npm ci --registry=https://registry.npmmirror.com --no-audit --no-fund

COPY . .

ARG VITE_API_URL=
ENV VITE_API_URL=$VITE_API_URL
ARG VITE_SCREEN_URL=
ENV VITE_SCREEN_URL=$VITE_SCREEN_URL

RUN npm run build

ARG REGISTRY_PREFIX=docker.m.daocloud.io
FROM ${REGISTRY_PREFIX}/library/nginx:alpine
COPY deploy/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
